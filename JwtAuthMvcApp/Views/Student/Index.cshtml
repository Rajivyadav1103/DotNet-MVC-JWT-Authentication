<div class="row">

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="row">

                    <div class="col-md-12">
                        <label>StudentName</label>
                        <input type="text" class="form-control txtstudentname" />
                    </div>
                    <div class="col-md-12">
                        <label>Age</label>
                        <input type="text" class="form-control  StudentAge" />
                    </div><br />

                    <div class="col-md-12">
                        <label>Course</label>
                        <input type="text" class="form-control txtcourse" />
                    </div>

                    <div class="col-md-12">
                        <label>Email</label>
                        <input type="text" class="form-control txtemail" />
                    </div>
                    <div class="col-md-12">
                        <label>PhoneNumber</label>
                        <input type="text" class="form-control txtphonenumber" />
                    </div>
                    <div class="col-md-12">
                        <br />
                        <button type="button" class="btn btn-danger btnCancel"><i class="fa-solid fa-magnifying-glass"></i>Cancel</button>
                        <button type="button" class="btn btn-success btnAdd"><i class="fa-solid fa-address-book"></i> Add Students</button>
                    </div>

                </div>

            </div>

        </div>
    </div>

    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <label>search Name</label>
                        <input type="text" class="form-control searchName" />
                    </div>

                    <div class="col-md-3">
                        <label>Search Email</label>
                        <input type="text" class="form-control Searchemail" />
                    </div>

                    <div class="col-md-3 mt-4">
                        <button type="button" class="btn btn-danger btnsearchcancel">cancel</button>
                        <button type="button" class="btn btn-primary btnserach">Search</button>
                    </div>

                </div>
            </div>
        </div>
    </div> 
    
</div>

<div class="row mt-3">
    <div class="col-md-8">
        <div class="card>">
            <div class="card-body"style="overflow:auto;" >
                <!-- Table to show students -->
                <table class="table table table-hover" id="studentTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Course</th>
                            <th>Email</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Students will be appended here -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {

            $(document).on('click','.btnancel',function(){
                var ok =confirm("are you sure to cancel the form ?");
                if (ok == true){
                    clearForm();
                }
            });

            $(document).on('click', '.btnAdd', function () {

                var xyz = {
                    StudentName: $('.txtstudentname').val().trim(),
                    StudentAge: $('.StudentAge').val().trim(),
                    StudentCourse: $('.txtcourse').val().trim(),
                    StudentEmail: $('.txtemail').val().trim(),
                    StudentPhoneNumber: $('.txtphonenumber').val().trim()
                };

                if (xyz.StudentName === "") {
                    toastr.error("Enter your full name", "Error");
                }
                else if (xyz.StudentAge === "") {
                    toastr.error("Enter your age", "Error");
                }
                else if (xyz.StudentCourse === "") {
                    toastr.error("Enter your course", "Error");
                }
                else if (xyz.StudentEmail === "") {
                    toastr.error("Enter your email", "Error");
                }
                else if (xyz.StudentPhoneNumber === "") {
                    toastr.error("Enter your phone number", "Error");
                }
                else {

                    $.ajax({
                        type: 'POST',   // ✅ must match controller
                        url: '@Url.Action("AddStudent", "Student")',
                        data: xyz,
                        success: function (res) {

                            if (res.success) {
                                toastr.success(res.message, "Success");
                                clearForm();
                            } else {
                                toastr.error(res.message, "Error");
                            }
                        },
                        error: function () {
                            toastr.error("Something went wrong");
                        }
                    });

                }

            });

        });

        function clearForm() {
            $('.txtstudentname').val('');
            $('.StudentAge').val('');
            $('.txtcourse').val('');
            $('.txtemail').val('');
            $('.txtphonenumber').val('');
        }
    </script>
}