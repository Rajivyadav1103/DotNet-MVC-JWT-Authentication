<div class="row">

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="row">

                    <div class="col-md-12">
                        <label>StudentName</label>
                        <input type="text" class="form-control txtstudentname" />
                    </div>

                    <div class="col-md-12">
                        <label>Age</label>
                        <input type="text" class="form-control StudentAge" />
                    </div>

                    <div class="col-md-12">
                        <label>Course</label>
                        <input type="text" class="form-control txtcourse" />
                    </div>

                    <div class="col-md-12">
                        <label>Email</label>
                        <input type="text" class="form-control txtemail" />
                    </div>

                    <div class="col-md-12">
                        <label>PhoneNumber</label>
                        <input type="text" class="form-control txtphonenumber" />
                    </div>

                    <div class="col-md-12 mt-2">
                        <button type="button" class="btn btn-danger btnCancel">Cancel</button>
                        <button type="button" class="btn btn-success btnAdd">Add Students</button>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>

<div class="row mt-3">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body" style="overflow:auto;">
                <table class="table table-hover" id="studentTable">
                    <thead>
                        <tr>
                            <th>SN</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Course</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Action</th>

                        </tr>
                    </thead>
                    <tbody class="main-data">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

             // ✅ MUST have toastr.options
    toastr.options = {
        "closeButton": true,          // shows close button
       
        "positionClass": "toast-top-right", // position
        
    };

            loadData();
        });


      $(document).on('click','.btnCancel',function(){

          var ok =confirm ("are you sure to cancel the form?");

          if(ok ==true){
              clearForm();
          }

      });




        // SAVE
        $(document).on('click', '.btnAdd', function () {

            var xyz = {
                Name: $('.txtstudentname').val(),                // ✅ FIX (StudentName → Name)
                Age: parseInt($('.StudentAge').val()),           // ✅ FIX (string → int)
                Course: $('.txtcourse').val(),                   // ✅ FIX (Course)
                Email: $('.txtemail').val(),
                PhoneNumber: $('.txtphonenumber').val()
            };

            if (!xyz.Name || !xyz.Age || !xyz.Course || !xyz.Email || !xyz.PhoneNumber) {
                // alert("All fields required");
                toastr.success(res.message);
                return;
            }

            $.ajax({
                type: 'POST',
                url: '@Url.Action("AddStudent", "Student")',
                data: JSON.stringify(xyz),
                contentType: 'application/json; charset=utf-8',
                success: function (res) {
                    // alert(res.message);
                    toastr.success(res.message);
                    clearForm();
                    loadData();
                }
            });

        });

        // LOAD DATA
        function loadData() {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetStudents", "Student")',
                success: function (data) {

                    var html = '';

                    $.each(data, function (index, item) {
                        html += '<tr>';
                             html += '<td>' + (index + 1 )+ '</td>';
                        html += '<td>' + item.name + '</td>';         // ✅ match model
                        html += '<td>' + item.age + '</td>';
                        html += '<td>' + item.course + '</td>';
                        html += '<td>' + item.email + '</td>';
                        html += '<td>' + item.phoneNumber + '</td>';
                                  // html += '<td><button class="btn btn-primary btnedit   btn-sm me-1"  data-key=" '+ item.StudentId +'  "  >Edit</button><button class="btn btndelete btn-danger btn-sm">Delete</button></td>';

                                      html += '<td><button class="btn btn-primary btnedit btn-sm me-1" data-key="' + item.studentId + '">Edit</button><button class="btn btndelete btn-danger btn-sm">Delete</button></td>';

                        html += '</tr>';
                    });

                    $('.main-data').html(html);
                }
            });
        }


                 $(document).on('click', '.btnAdd', function () {

            var id = $(this).attr('data-id'); // ✅ get id (if edit)

            var xyz = {
                StudentId: id ? parseInt(id) : 0,
                Name: $('.txtstudentname').val(),
                Age: parseInt($('.StudentAge').val()),
                Course: $('.txtcourse').val(),
                Email: $('.txtemail').val(),
                PhoneNumber: $('.txtphonenumber').val()
            };

            if (!xyz.Name || !xyz.Age || !xyz.Course || !xyz.Email || !xyz.PhoneNumber) {
                toastr.error("All fields required"); // ✅ FIX (was wrong)
                return;
            }

            var url = id
                ? '@Url.Action("UpdateStudent", "Student")'   // ✅ UPDATE
                : '@Url.Action("AddStudent", "Student")';     // ✅ ADD

            $.ajax({
                type: 'POST',
                url: url,
                data: JSON.stringify(xyz),
                contentType: 'application/json; charset=utf-8',
                success: function (res) {
                    toastr.success(res.message);
                    clearForm();
                    $('.btnAdd').removeAttr('data-id'); // ✅ reset
                    $('.btnAdd').text('Add Students');  // ✅ reset button text
                    loadData();
                }
            });

        });


               $(document).on('click', '.btndelete', function () {

            var key = $(this).closest('tr').find('.btnedit').data('key');

            if (confirm("Are you sure to delete?")) {
                $.ajax({
                    type: 'DELETE',
                    url: '@Url.Action("DeleteStudent", "Student")?id=' + key,
                    success: function (res) {
                        toastr.success(res.message);
                        loadData();
                    }
                });
            }

        });

        // CLEAR
        function clearForm() {
            $('.txtstudentname').val('');
            $('.StudentAge').val('');
            $('.txtcourse').val('');
            $('.txtemail').val('');
            $('.txtphonenumber').val('');
        }
    </script>
}