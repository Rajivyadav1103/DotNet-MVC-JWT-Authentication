<div class="row">

    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="row">

                    <div class="col-md-12">
                        <label>StudentName</label>
                        <input type="text" class="form-control txtstudentname" />
                    </div>

                    <div class="col-md-12">
                        <label>Age</label>
                        <input type="text" class="form-control StudentAge" />
                    </div>

                    <div class="col-md-12">
                        <label>Course</label>
                        <input type="text" class="form-control txtcourse" />
                    </div>

                    <div class="col-md-12">
                        <label>Email</label>
                        <input type="text" class="form-control txtemail" />
                    </div>

                    <div class="col-md-12">
                        <label>PhoneNumber</label>
                        <input type="text" class="form-control txtphonenumber" />
                    </div>

                    <div class="col-md-12 mt-2">
                        <button type="button" class="btn btn-danger btnCancel">Cancel</button>
                        <button type="button" class="btn btn-success btnAdd">Add Students</button>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>

<div class="row mt-3">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body" style="overflow:auto;">
                <table class="table table-hover" id="studentTable">
                    <thead>
                        <tr>
                            @* <th>#</th> *@
                            <th>Name</th>
                            <th>Age</th>
                            <th>Course</th>
                            <th>Email</th>
                            <th>Phone</th>
                        </tr>
                    </thead>
                    <tbody class="main-data">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <script>
        $(document).ready(function () {

             // ✅ MUST have toastr.options
    toastr.options = {
        "closeButton": true,          // shows close button
       
        "positionClass": "toast-top-right", // position
        
    };

            loadData();
        });

        // SAVE
        $(document).on('click', '.btnAdd', function () {

            var xyz = {
                Name: $('.txtstudentname').val(),                // ✅ FIX (StudentName → Name)
                Age: parseInt($('.StudentAge').val()),           // ✅ FIX (string → int)
                Course: $('.txtcourse').val(),                   // ✅ FIX (Course)
                Email: $('.txtemail').val(),
                PhoneNumber: $('.txtphonenumber').val()
            };

            if (!xyz.Name || !xyz.Age || !xyz.Course || !xyz.Email || !xyz.PhoneNumber) {
                // alert("All fields required");
                toastr.success(res.message);
                return;
            }

            $.ajax({
                type: 'POST',
                url: '@Url.Action("AddStudent", "Student")',
                data: JSON.stringify(xyz),
                contentType: 'application/json; charset=utf-8',
                success: function (res) {
                    // alert(res.message);
                    toastr.success(res.message);
                    clearForm();
                    loadData();
                }
            });

        });

        // LOAD DATA
        function loadData() {
            $.ajax({
                type: 'GET',
                url: '@Url.Action("GetStudents", "Student")',
                success: function (data) {

                    var html = '';

                    $.each(data, function (index, item) {
                        html += '<tr>';
                        html += '<td>' + item.name + '</td>';         // ✅ match model
                        html += '<td>' + item.age + '</td>';
                        html += '<td>' + item.course + '</td>';
                        html += '<td>' + item.email + '</td>';
                        html += '<td>' + item.phoneNumber + '</td>';
                        html += '</tr>';
                    });

                    $('.main-data').html(html);
                }
            });
        }

        // CLEAR
        function clearForm() {
            $('.txtstudentname').val('');
            $('.StudentAge').val('');
            $('.txtcourse').val('');
            $('.txtemail').val('');
            $('.txtphonenumber').val('');
        }
    </script>
}