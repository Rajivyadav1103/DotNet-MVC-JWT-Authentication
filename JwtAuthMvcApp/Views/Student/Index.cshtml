<div class="row">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <div class="row">

                    <div class="col-md-12">
                        <label>Student Name</label>
                        <input type="text" class="form-control txtstudentname" />
                    </div>

                    <div class="col-md-12">
                        <label>Age</label>
                        <input type="number" class="form-control StudentAge" />
                    </div>

                    <div class="col-md-12">
                        <label>Course</label>
                        <input type="text" class="form-control txtcourse" />
                    </div>

                    <div class="col-md-12">
                        <label>Email</label>
                        <input type="email" class="form-control txtemail" />
                    </div>

                    <div class="col-md-12">
                        <label>Phone Number</label>
                        <input type="text" class="form-control txtphonenumber" />
                    </div>

                    <div class="col-md-12 mt-2">
                        <button type="button" class="btn btn-danger btnCancel">Cancel</button>
                        <button type="button" class="btn btn-success btnAdd">Add Students</button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- TABLE -->
<div class="row mt-3">
    <div class="col-md-12">
        <div class="card">
            <div class="card-body" style="overflow:auto;">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>SN</th>
                            <th>Name</th>
                            <th>Age</th>
                            <th>Course</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody class="main-data"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {

            toastr.options = {
                closeButton: true,
                positionClass: "toast-top-right"
            };

            loadData();
        });


        // ================= ADD / UPDATE =================
        $(document).on('click', '.btnAdd', function () {

            var id = $(this).attr('data-id');

            var xyz = {
                StudentId: id ? parseInt(id) : 0,
                Name: $('.txtstudentname').val(),
                Age: parseInt($('.StudentAge').val()),
                course: $('.txtcourse').val(),   // ✅ small c
                Email: $('.txtemail').val(),
                PhoneNumber: $('.txtphonenumber').val()
            };

            if (!xyz.Name || !xyz.Age || !xyz.course || !xyz.Email || !xyz.PhoneNumber) {
                toastr.error("All fields required");
                return;
            }

            var url = id
                ? '@Url.Action("UpdateStudent", "Student")'
                : '@Url.Action("AddStudent", "Student")';

            $.ajax({
                type: 'POST',
                url: url,
                data: JSON.stringify(xyz),
                contentType: 'application/json',
                success: function (res) {
                    toastr.success(res.message);
                    clearForm();
                    $('.btnAdd').removeAttr('data-id').text('Add Students');
                    loadData();
                }
            });
        });


        // ================= LOAD =================
        function loadData() {
            $.get('@Url.Action("GetStudents", "Student")', function (data) {

                var html = '';

                $.each(data, function (i, item) {
                    html += `<tr>
                                <td>${i + 1}</td>
                                <td>${item.name}</td>
                                <td>${item.age}</td>
                                <td>${item.course}</td>
                                <td>${item.email}</td>
                                <td>${item.phoneNumber}</td>
                                <td>
                                    <button class="btn btn-primary btnedit btn-sm" data-id="${item.studentId}">Edit</button>
                                    <button class="btn btn-danger btndelete btn-sm">Delete</button>
                                </td>
                             </tr>`;
                });

                $('.main-data').html(html);
            });
        }


        // ================= EDIT =================
        $(document).on('click', '.btnedit', function () {

            var row = $(this).closest('tr');

            $('.txtstudentname').val(row.find('td:eq(1)').text());
            $('.StudentAge').val(row.find('td:eq(2)').text());
            $('.txtcourse').val(row.find('td:eq(3)').text());
            $('.txtemail').val(row.find('td:eq(4)').text());
            $('.txtphonenumber').val(row.find('td:eq(5)').text());

            var id = $(this).data('id');

            $('.btnAdd').attr('data-id', id).text('Update Student');
        });


        // ================= DELETE =================
        $(document).on('click', '.btndelete', function () {

            var id = $(this).closest('tr').find('.btnedit').data('id');

            if (confirm("Delete this record?")) {
                $.ajax({
                    type: 'DELETE',
                    url: '@Url.Action("DeleteStudent", "Student")?id=' + id,
                    success: function (res) {
                        toastr.success(res.message);
                        loadData();
                    }
                });
            }
        });


        // ================= CLEAR =================
        function clearForm() {
            $('.txtstudentname').val('');
            $('.StudentAge').val('');
            $('.txtcourse').val('');
            $('.txtemail').val('');
            $('.txtphonenumber').val('');
        }

        $(document).on('click', '.btnCancel', function () {
            clearForm();
            $('.btnAdd').removeAttr('data-id').text('Add Students');
        });
    </script>
}